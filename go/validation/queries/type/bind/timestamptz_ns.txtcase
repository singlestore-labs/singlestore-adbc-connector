// part: metadata

[setup]
drop = "test_timestamptz"

[tags]
sql-type-name = "TIMESTAMP"

// part: setup_query

CREATE TABLE test_timestamptz (
    idx INT,
    res TIMESTAMP(6),
    res2 TIMESTAMP(6)
);

// part: bind

{"idx": 3, "res": 1684158330000000000, "res2": 1684158330000000000}
{"idx": 2, "res": 946684800000000000, "res2": 946684800000000000}
{"idx": 1, "res": 1000000000, "res2": 1000000000}
{"idx": 4, "res": 2147483647499000000, "res2": 2147483647499000000}
{"idx": 0, "res": null, "res2": null}


// part: expected_schema

{
    "format": "+s",
    "children": [
        {
            "name": "res",
            "format": "tsu:UTC",
            "flags": ["nullable"]
        },
        {
            "name": "res2",
            "format": "tsu:UTC",
            "flags": ["nullable"]
        }
    ]
}

// part: expected

{"res": null, "res2": null}
{"res": 1000000, "res2": 1000000}
{"res": 946684800000000, "res2": 946684800000000}
{"res": 1684158330000000, "res2": 1684158330000000}
{"res": 2147483647499000, "res2": 2147483647499000}
