// part: metadata

[tags]
sql-type-name = "TIME"

// part: setup_query

CREATE TABLE test_time (
    idx INT,
    res TIME(0)
);

// part: expected_schema

{
    "format": "+s",
    "children": [
        {
            "name": "res",
            "format": "tts",
            "flags": ["nullable"]
        }
    ]
}

// part: expected

{"res": 0}
{"res": null}
{"res": 49531}
{"res": 45045}
{"res": 86399}
